# Supabase — from Project Settings → API in supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Used only by server-side migration scripts. NEVER expose to the browser.
SUPABASE_SERVICE_KEY=

# Optional — for the AI Generator view (calls Claude/Anthropic from the server route)
ANTHROPIC_API_KEY=
GROQ_API_KEY=
